{
    "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
    "formatter": {
        "enabled": true,
        "useEditorconfig": true,
        "lineWidth": 80,
        "indentStyle": "space",
        "indentWidth": 4,
        "bracketSpacing": true
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "jsxQuoteStyle": "double",
            "trailingCommas": "all",
            "bracketSameLine": false
        }
    },
    "json": {
        "formatter": {
            "trailingCommas": "none"
        }
    },
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "ignoreUnknown": true,
        "includes": [
            "**",
            "!!**/sst-env.d.ts",
            "!!packages/app/tauri/tauri-plugin-player/permissions",
            "!!**/cdk.context.json",
            "!!**/.direnv",
            "!!**/target",
            "!!packages/opus_native/libopus"
        ]
    }
}
